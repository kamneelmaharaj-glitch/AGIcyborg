# ==========================
# AGIcyborg Secure .gitignore
# ==========================

# Environment / secrets
.env
.env.*
!.env.template
.streamlit/secrets.toml

# Keys / licenses / encrypted runtime artifacts
tools/keys/*
!tools/keys/*public.key
tools/*.jwt
tools/*.pem
tools/*.bin
tools/*.enc
tools/*.bak
*.key
*.crt

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb
*.egg-info/
*.log

# Virtual environments
.venv/
venv/

# Test artifacts
.coverage
htmlcov/
.cache/
pytest_cache/
*.pytest_cache/

# Build outputs
build/
dist/
*.egg
*.whl

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Temporary files
*.tmp
*.old

# Node / frontend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Supabase local config
supabase/config.toml
supabase/.env
supabase/.supabase